{
  "name": "@mistle/tests",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "oxlint --type-aware --deny-warnings -c ../.oxlintrc.jsonc .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:system:prepare": "pnpm --filter @mistle/control-plane-api... build && pnpm --filter @mistle/control-plane-worker... build",
    "test:system": "pnpm run test:system:prepare && vitest -c vitest.system.config.ts --run --passWithNoTests",
    "test:e2e": "playwright test --config playwright.config.ts --pass-with-no-tests"
  },
  "devDependencies": {
    "@mistle/db": "workspace:*",
    "@mistle/test-harness": "workspace:*",
    "@types/pg": "^8.18.0",
    "pg": "^8.19.0",
    "vite-tsconfig-paths": "^6.1.0"
  }
}
