{
  "name": "@mistle/sandbox-runtime",
  "private": true,
  "type": "module",
  "scripts": {
    "build:native": "pnpm --filter @mistle/sandbox-rs-napi build",
    "dev": "tsx watch src/main.ts",
    "dev:bootstrap": "pnpm run build:native && tsx watch src/bootstrap/main.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build:sea:bundle": "node ./scripts/build-sea-bundles.mjs",
    "build:sea": "node ./scripts/build-sea.mjs",
    "test:sea": "pnpm run build:sea && node ./scripts/smoke-sea.mjs",
    "start": "node dist/main.js",
    "start:bootstrap": "pnpm run build:native && node dist/bootstrap/main.js",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "node ./scripts/ensure-native-built.mjs && vitest run -c vitest.config.ts --passWithNoTests",
    "test:integration": "node ./scripts/ensure-native-built.mjs && vitest run -c vitest.integration.config.ts --passWithNoTests",
    "test:property": "vitest run -c vitest.property.config.ts --passWithNoTests",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@mistle/integrations-core": "workspace:*",
    "@mistle/integrations-definitions": "workspace:*",
    "@mistle/sandbox-rs-napi": "workspace:*",
    "@mistle/sandbox-session-protocol": "workspace:*",
    "@mistle/time": "workspace:*",
    "undici": "7.24.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.3.0",
    "@types/ws": "^8.18.1",
    "esbuild": "0.27.4",
    "postject": "1.0.0-alpha.6"
  }
}
