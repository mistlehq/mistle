{
  "name": "@mistle/control-plane",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./src/instrument.ts src/index.ts",
    "dev:worker": "tsx watch --import ./src/worker/instrument.ts src/worker/index.ts",
    "db:migrate": "tsx scripts/run-control-plane-migrations.ts",
    "db:seed:integration-targets": "tsx scripts/seed-integration-targets.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && tsc -p tsconfig.build.scripts.json && tsc-alias -p tsconfig.build.scripts.json",
    "start": "node --import ./dist/src/instrument.js dist/src/index.js",
    "start:worker": "node --import ./dist/src/worker/instrument.js dist/src/worker/index.js",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc . && pnpm run openapi:check",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run -c vitest.config.ts && vitest run -c vitest.worker.config.ts --passWithNoTests",
    "test:integration": "vitest run -c vitest.integration.config.ts && vitest run -c vitest.worker.integration.config.ts",
    "test:property": "vitest run -c vitest.property.config.ts --passWithNoTests",
    "openapi:generate": "tsx --tsconfig tsconfig.scripts.json src/openapi/generate-spec.ts",
    "openapi:check": "tsx --tsconfig tsconfig.scripts.json src/openapi/check-spec-drift.ts",
    "codex:app-server:generate": "tsx scripts/worker/generate-codex-app-server-types.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.5.3",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-openapi": "^1.2.2",
    "@mistle/automations": "workspace:*",
    "@mistle/config": "workspace:*",
    "@mistle/control-plane-internal-client": "workspace:*",
    "@mistle/data-plane-trpc": "workspace:*",
    "@mistle/db": "workspace:*",
    "@mistle/emails": "workspace:*",
    "@mistle/gateway-connection-auth": "workspace:*",
    "@mistle/http": "workspace:*",
    "@mistle/integrations-core": "workspace:*",
    "@mistle/integrations-definitions": "workspace:*",
    "@mistle/logging": "workspace:*",
    "@mistle/sandbox": "workspace:*",
    "@mistle/sandbox-runtime-plan-compiler": "workspace:*",
    "@mistle/sandbox-session-protocol": "workspace:*",
    "@mistle/telemetry": "workspace:*",
    "@mistle/time": "workspace:*",
    "better-auth": "1.5.3",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.5",
    "openworkflow": "^0.8.1",
    "pg": "^8.19.0",
    "postgres": "^3.4.8",
    "typeid-js": "^1.2.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mistle/test-harness": "workspace:*",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1"
  }
}
