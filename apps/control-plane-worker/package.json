{
  "name": "@mistle/control-plane-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./src/instrument.ts src/index.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node --import ./dist/instrument.js dist/index.js",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run -c vitest.config.ts --passWithNoTests",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:property": "vitest run --passWithNoTests",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@mistle/automations": "workspace:*",
    "@mistle/config": "workspace:*",
    "@mistle/control-plane-internal-client": "workspace:*",
    "@mistle/data-plane-trpc": "workspace:*",
    "@mistle/db": "workspace:*",
    "@mistle/emails": "workspace:*",
    "@mistle/logging": "workspace:*",
    "@mistle/sandbox-session-protocol": "workspace:*",
    "@mistle/telemetry": "workspace:*",
    "@mistle/time": "workspace:*",
    "@mistle/workflows": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "pg": "^8.19.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@mistle/test-harness": "workspace:*",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1"
  }
}
