{
  "name": "@mistle/control-plane-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./src/instrument.ts ./node_modules/@openworkflow/cli/dist/cli.js worker start --config ./openworkflow.config.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && tsc -p tsconfig.build.openworkflow.json && tsc-alias -p tsconfig.build.openworkflow.json",
    "start": "node --import ./dist/instrument.js ./node_modules/@openworkflow/cli/dist/cli.js worker start --config ./dist/openworkflow.config.js",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run -c vitest.config.ts --passWithNoTests",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:property": "vitest run --passWithNoTests",
    "codex:app-server:generate": "tsx scripts/generate-codex-app-server-types.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@mistle/automations": "workspace:*",
    "@mistle/config": "workspace:*",
    "@mistle/control-plane-internal-client": "workspace:*",
    "@mistle/data-plane-trpc": "workspace:*",
    "@mistle/db": "workspace:*",
    "@mistle/emails": "workspace:*",
    "@mistle/integrations-core": "workspace:*",
    "@mistle/integrations-definitions": "workspace:*",
    "@mistle/logging": "workspace:*",
    "@mistle/sandbox-session-protocol": "workspace:*",
    "@mistle/telemetry": "workspace:*",
    "@mistle/time": "workspace:*",
    "@mistle/workflow-registry": "workspace:*",
    "@mistle/workflows": "workspace:*",
    "@openworkflow/cli": "^0.4.3",
    "drizzle-orm": "^0.45.1",
    "openworkflow": "^0.8.1",
    "pg": "^8.20.0",
    "typeid-js": "^1.2.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mistle/test-harness": "workspace:*",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1"
  }
}
