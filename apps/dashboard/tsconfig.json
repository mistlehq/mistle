{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "lint/**/*.ts",
    "scripts/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "src/**/*.stories.tsx",
    "src/**/*.story-fixtures.ts",
    "src/**/*.story-fixtures.tsx",
    "src/storybook/**"
  ]
}
