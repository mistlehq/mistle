{
  "name": "@mistle/dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/vite-with-config.ts dev",
    "dev:e2e": "tsx scripts/vite-with-config.ts dev --host localhost --port 4173 --strictPort",
    "build": "tsx scripts/vite-with-config.ts build",
    "preview": "tsx scripts/vite-with-config.ts preview",
    "lint": "oxlint --deny-warnings -c ./.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run -c vitest.integration.config.ts --passWithNoTests",
    "openapi:generate": "tsx scripts/generate-control-plane-client.ts",
    "openapi:check": "tsx lint/check-control-plane-client-drift.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@mistle/integrations-core": "workspace:*",
    "@mistle/integrations-definitions": "workspace:*",
    "@mistle/sandbox-session-client": "workspace:*",
    "@mistle/time": "workspace:*",
    "@mistle/ui": "workspace:*",
    "@phosphor-icons/react": "^2.1.7",
    "@pierre/diffs": "^1.1.3",
    "@rjsf/core": "~6.4.1",
    "@rjsf/utils": "~6.4.1",
    "@rjsf/validator-ajv8": "~6.4.1",
    "@streamdown/code": "^1.1.1",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-query": "~5.90.21",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-auth": "1.5.4",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "~7.13.0",
    "streamdown": "^2.4.0"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "0.2.2",
    "@storybook/react-vite": "^10.3.2",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/react": "^16.3.0",
    "@types/pg": "^8.18.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.13.0",
    "pg": "^8.20.0",
    "smol-toml": "^1.6.0",
    "storybook": "^10.2.19",
    "vite": "^8.0.1",
    "zod": "^4.1.12"
  }
}
