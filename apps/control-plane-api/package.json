{
  "name": "@mistle/control-plane-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./src/instrument.ts src/index.ts",
    "db:migrate": "tsx scripts/run-control-plane-migrations.ts",
    "integration-targets:sync": "tsx scripts/run-integration-targets-sync.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && tsc -p tsconfig.build.scripts.json && tsc-alias -p tsconfig.build.scripts.json",
    "start": "node --import ./dist/instrument.js dist/index.js",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc . && pnpm run openapi:check",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run -c vitest.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:property": "vitest run -c vitest.property.config.ts --passWithNoTests",
    "openapi:generate": "tsx --tsconfig tsconfig.scripts.json scripts/openapi/generate-spec.ts",
    "openapi:check": "tsx --tsconfig tsconfig.scripts.json scripts/openapi/check-spec-drift.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-openapi": "^1.2.2",
    "@mistle/config": "workspace:*",
    "@mistle/data-plane-internal-client": "workspace:*",
    "@mistle/db": "workspace:*",
    "@mistle/gateway-connection-auth": "workspace:*",
    "@mistle/http": "workspace:*",
    "@mistle/integrations-core": "workspace:*",
    "@mistle/integrations-definitions": "workspace:*",
    "@mistle/logging": "workspace:*",
    "@mistle/telemetry": "workspace:*",
    "@mistle/time": "workspace:*",
    "@mistle/workflow-registry": "workspace:*",
    "better-auth": "1.5.4",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.8",
    "openworkflow": "^0.8.1",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "typeid-js": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mistle/gateway-tunnel-auth": "workspace:*",
    "@mistle/test-harness": "workspace:*",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "ws": "^8.20.0"
  }
}
