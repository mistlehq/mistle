{
  "name": "@mistle/control-plane-api",
  "private": true,
  "type": "module",
  "exports": {
    "./testing": {
      "types": "./src/testing/index.ts",
      "node": "./src/testing/index.ts",
      "import": "./src/testing/index.ts",
      "default": "./src/testing/index.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "db:migrate": "tsx src/scripts/run-control-plane-migrations.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc . && pnpm run openapi:check",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run -c vitest.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:property": "vitest run -c vitest.property.config.ts --passWithNoTests",
    "openapi:generate": "tsx --tsconfig tsconfig.scripts.json src/openapi/generate-spec.ts",
    "openapi:check": "tsx --tsconfig tsconfig.scripts.json src/openapi/check-spec-drift.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@hono/node-server": "^1.19.4",
    "@hono/zod-openapi": "^1.2.2",
    "@mistle/config": "workspace:*",
    "@mistle/data-plane-trpc": "workspace:*",
    "@mistle/db": "workspace:*",
    "@mistle/emails": "workspace:*",
    "@mistle/gateway-connection-auth": "workspace:*",
    "@mistle/http": "workspace:*",
    "@mistle/integrations-core": "workspace:*",
    "@mistle/integrations-definitions": "workspace:*",
    "@mistle/logging": "workspace:*",
    "@mistle/time": "workspace:*",
    "@mistle/workflows": "workspace:*",
    "better-auth": "1.4.19",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.3",
    "pg": "^8.19.0",
    "typeid-js": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mistle/test-core": "workspace:*",
    "@types/pg": "^8.15.6"
  }
}
