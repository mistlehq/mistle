{
  "name": "@mistle/control-plane-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "db:migrate": "tsx src/scripts/run-control-plane-migrations.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run -c vitest.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:property": "vitest run -c vitest.property.config.ts --passWithNoTests",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@hono/node-server": "^1.19.4",
    "@hono/zod-openapi": "^1.2.2",
    "@mistle/config": "workspace:*",
    "@mistle/db": "workspace:*",
    "@mistle/http": "workspace:*",
    "@mistle/time": "workspace:*",
    "@mistle/workflows": "workspace:*",
    "better-auth": "1.4.18",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.10.6",
    "pg": "^8.18.0",
    "typeid-js": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mistle/emails": "workspace:*",
    "@mistle/test-harness": "workspace:*",
    "@types/pg": "^8.15.6"
  }
}
