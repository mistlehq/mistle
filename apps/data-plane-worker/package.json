{
  "name": "@mistle/data-plane-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./src/instrument.ts src/index.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node --import ./dist/instrument.js dist/index.js",
    "dev:openworkflow": "tsx watch --import ./src/instrument.ts ./node_modules/@openworkflow/cli/dist/cli.js worker start --config ./openworkflow.config.ts",
    "build:openworkflow": "tsc -p tsconfig.build.openworkflow.json && tsc-alias -p tsconfig.build.openworkflow.json",
    "start:openworkflow": "node --import ./dist/instrument.js ./node_modules/@openworkflow/cli/dist/cli.js worker start --config ./dist/openworkflow.config.js",
    "lint": "oxlint --type-aware --deny-warnings -c ../../.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:property": "vitest run --passWithNoTests",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@mistle/config": "workspace:*",
    "@mistle/db": "workspace:*",
    "@mistle/gateway-tunnel-auth": "workspace:*",
    "@mistle/logging": "workspace:*",
    "@mistle/sandbox": "workspace:*",
    "@mistle/telemetry": "workspace:*",
    "@mistle/time": "workspace:*",
    "@mistle/workflow-registry": "workspace:*",
    "@mistle/workflows": "workspace:*",
    "@openworkflow/cli": "^0.4.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "openworkflow": "^0.8.1",
    "pg": "^8.20.0",
    "typeid-js": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0"
  }
}
