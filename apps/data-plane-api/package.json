{
  "name": "@mistle/data-plane-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./src/instrument.ts src/index.ts",
    "db:migrate": "tsx src/scripts/run-data-plane-migrations.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node --import ./dist/instrument.js dist/index.js",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc . && pnpm run openapi:check",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run -c vitest.config.ts --passWithNoTests",
    "test:integration": "vitest run -c vitest.integration.config.ts --passWithNoTests",
    "test:property": "vitest run --passWithNoTests",
    "openapi:generate": "tsx src/openapi/generate-spec.ts",
    "openapi:check": "tsx src/openapi/check-spec-drift.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-openapi": "^1.2.2",
    "@mistle/config": "workspace:*",
    "@mistle/db": "workspace:*",
    "@mistle/integrations-core": "workspace:*",
    "@mistle/logging": "workspace:*",
    "@mistle/sandbox": "workspace:*",
    "@mistle/telemetry": "workspace:*",
    "@mistle/time": "workspace:*",
    "@mistle/workflow-registry": "workspace:*",
    "@openworkflow/cli": "^0.4.3",
    "hono": "^4.12.7",
    "openworkflow": "^0.8.1",
    "pg": "^8.20.0",
    "typeid-js": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mistle/data-plane-internal-client": "workspace:*",
    "@mistle/test-harness": "workspace:*",
    "@types/pg": "^8.18.0"
  }
}
