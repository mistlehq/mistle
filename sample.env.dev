# Copy this file to .env.dev for local development.
# Do not commit .env.dev.

# Named tunnel token for your Cloudflare named tunnel.
# Get this with: cloudflared tunnel token <tunnel-name-or-id>
CLOUDFLARE_TUNNEL_TOKEN=

# Stable public hostname for control-plane-api tunnel ingress.
CONTROL_PLANE_API_TUNNEL_HOSTNAME=

# Stable public hostname for data-plane-gateway tunnel ingress.
DATA_PLANE_API_TUNNEL_HOSTNAME=

# Stable public hostname for tokenizer-proxy tunnel ingress.
TOKENIZER_PROXY_TUNNEL_HOSTNAME=
