{
  auto_https off
}

:8088 {
  handle /__healthz {
    header Content-Type application/json
    respond "{\"ok\":true}" 200
  }

  @authorized header Authorization "Bearer {$SERVICE_TOKEN}"

  handle @authorized {
    reverse_proxy {$DATA_PLANE_API_UPSTREAM} {
      header_up -Authorization
    }
  }

  handle {
    respond "unauthorized" 401
  }
}
