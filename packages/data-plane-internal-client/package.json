{
  "name": "@mistle/data-plane-internal-client",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./generated/schema.js": {
      "types": "./src/generated/schema.ts",
      "node": "./dist/generated/schema.js",
      "import": "./src/generated/schema.ts",
      "default": "./src/generated/schema.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "node": "./dist/*.js",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc . && pnpm run openapi:check",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "openapi:generate": "tsx scripts/generate-client.ts",
    "openapi:check": "tsx scripts/check-client-drift.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@mistle/db": "workspace:*",
    "@mistle/integrations-core": "workspace:*",
    "@mistle/sandbox": "workspace:*",
    "openapi-fetch": "^0.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0"
  }
}
