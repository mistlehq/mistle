{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "extends": ["../../.oxlintrc.jsonc"],
  "overrides": [
    {
      "files": ["src/**/*.ts"],
      "rules": {
        "eslint/no-restricted-globals": [
          "error",
          {
            "name": "vi",
            "message": "Do not use vi-based mocks/spies. Assert observable behavior instead.",
          },
          {
            "name": "jest",
            "message": "Do not use jest-based mocks/spies. Assert observable behavior instead.",
          },
        ],
      },
    },
    {
      "files": ["src/ui/**/*.ts", "src/**/ui-contract.ts"],
      "rules": {
        "eslint/no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["node:*", "@octokit/*"],
                "message": "UI contract modules must remain browser-safe and cannot import Node or server-only dependencies.",
              },
            ],
          },
        ],
      },
    },
    {
      "files": [
        "src/openai/agent.ts",
        "src/openai/variants/openai-default/agent/session-client.ts",
        "src/openai/variants/openai-default/agent/session-types.ts",
        "src/openai/variants/openai-default/agent/codex-json-rpc.ts",
        "src/openai/variants/openai-default/agent/codex-operations.ts",
        "src/openai/variants/openai-default/agent/is-record.ts",
        "src/openai/variants/openai-default/agent/thread-items.ts",
        "src/openai/variants/openai-default/agent/thread-items/**/*.ts",
      ],
      "rules": {
        "eslint/no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "node:*",
                  "@octokit/*",
                  "@mistle/codex-app-server-client",
                  "@mistle/codex-app-server-client/*",
                  "**/*.server",
                  "**/*.server.js",
                  "**/*.server.ts",
                ],
                "message": "OpenAI browser-safe agent modules must remain browser-safe and must not depend on Node or the transitional codex-app-server-client package.",
              },
            ],
          },
        ],
      },
    },
  ],
}
