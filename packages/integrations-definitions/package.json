{
  "name": "@mistle/integrations-definitions",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "node": "./dist/ui/index.js",
      "import": "./src/ui/index.ts",
      "default": "./src/ui/index.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "node": "./dist/*.js",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@mistle/integrations-core": "workspace:*",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/request": "^10.0.8",
    "@octokit/webhooks-methods": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@octokit/webhooks-examples": "^7.6.1",
    "@octokit/webhooks-types": "^7.6.1"
  }
}
