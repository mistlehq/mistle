{
  "name": "@mistle/integrations-definitions",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./agent": {
      "types": "./src/agent.server.ts",
      "node": "./dist/agent.server.js"
    },
    "./openai/agent": {
      "types": "./src/openai/agent.server.ts",
      "node": "./dist/openai/agent.server.js"
    },
    "./openai/agent/browser": {
      "types": "./src/openai/agent.ts",
      "node": "./dist/openai/agent.js",
      "import": "./src/openai/agent.ts",
      "default": "./src/openai/agent.ts"
    },
    "./forms": {
      "types": "./src/forms/index.ts",
      "node": "./dist/forms/index.js",
      "import": "./src/forms/index.ts",
      "default": "./src/forms/index.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "node": "./dist/*.js",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@mistle/codex-app-server-client": "workspace:*",
    "@mistle/integrations-core": "workspace:*",
    "@mistle/sandbox-session-client": "workspace:*",
    "@mistle/time": "workspace:*",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/request": "^10.0.8",
    "@octokit/webhooks-methods": "^6.0.0",
    "octokit": "^5.0.5",
    "smol-toml": "^1.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mistle/sandbox-session-protocol": "workspace:*",
    "@octokit/webhooks-examples": "^7.6.1",
    "@octokit/webhooks-types": "^7.6.1",
    "@types/ws": "^8.18.1",
    "ws": "^8.18.3"
  }
}
