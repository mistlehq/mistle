{
  "name": "@mistle/emails",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "node": "./dist/testing/index.js",
      "import": "./src/testing/index.ts",
      "default": "./src/testing/index.ts"
    },
    "./*.js": {
      "types": "./src/*",
      "node": "./dist/*.js",
      "import": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings -c ../../.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@react-email/components": "^1.0.1",
    "@react-email/render": "^2.0.4",
    "nodemailer": "^8.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11"
  }
}
