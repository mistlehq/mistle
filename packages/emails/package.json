{
  "name": "@mistle/emails",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "node": "./dist/testing/index.js",
      "import": "./src/testing/index.ts",
      "default": "./src/testing/index.ts"
    },
    "./*.js": {
      "types": "./src/*",
      "node": "./dist/*.js",
      "import": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:all": "pnpm test && pnpm test:integration",
    "preview": "node ./scripts/jsx-email-cli-compat.mjs preview ./preview",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "jsx-email": "^2.8.4",
    "nodemailer": "^8.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@mistle/test-harness": "workspace:*",
    "@types/nodemailer": "^7.0.11",
    "zod": "^4.3.6"
  }
}
