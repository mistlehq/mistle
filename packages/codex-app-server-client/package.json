{
  "name": "@mistle/codex-app-server-client",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./browser": {
      "types": "./src/browser.ts",
      "node": "./dist/browser.js",
      "import": "./src/browser.ts",
      "default": "./src/browser.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "node": "./dist/node.js",
      "import": "./src/node.ts",
      "default": "./src/node.ts"
    },
    "./thread-items.js": {
      "types": "./src/thread-items.ts",
      "node": "./dist/thread-items.js",
      "import": "./src/thread-items.ts",
      "default": "./src/thread-items.ts"
    },
    "./generated/codex-app-server/ts/*.js": {
      "types": "./src/generated/codex-app-server/ts/*.ts",
      "node": "./dist/generated/codex-app-server/ts/*.js",
      "import": "./src/generated/codex-app-server/ts/*.ts",
      "default": "./src/generated/codex-app-server/ts/*.ts"
    },
    "./generated/codex-app-server/json-schema/*": "./generated/codex-app-server/json-schema/*",
    "./*.js": {
      "types": "./src/*.ts",
      "node": "./dist/*.js",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "codex:app-server:generate": "tsx scripts/generate-codex-app-server-types.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@mistle/sandbox-session-client": "workspace:*",
    "zod": "^4.1.12"
  }
}
