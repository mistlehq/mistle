{
  "name": "@mistle/integrations-core",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "node": "./dist/*.js",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "shell-quote": "^1.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/shell-quote": "^1.7.5"
  }
}
