{
  "name": "@mistle/test-environments",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "pnpm test:integration",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@mistle/control-plane-api": "workspace:*",
    "@mistle/control-plane-worker": "workspace:*",
    "@mistle/data-plane-api": "workspace:*",
    "@mistle/db": "workspace:*",
    "@mistle/test-core": "workspace:*",
    "@mistle/workflows": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.6"
  }
}
