{
  "name": "@mistle/sandbox-session-protocol",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./generated/types.js": {
      "types": "./src/generated/types.ts",
      "node": "./dist/generated/types.js",
      "import": "./src/generated/types.ts",
      "default": "./src/generated/types.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "node": "./dist/*.js",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc . && pnpm run protocol:check",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "protocol:generate": "tsx scripts/generate-types.ts",
    "protocol:check": "tsx scripts/check-types-drift.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "json-schema-to-typescript": "15.0.4"
  }
}
