{
  "name": "@mistle/workflows",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./control-plane": {
      "types": "./src/control-plane/index.ts",
      "node": "./dist/control-plane/index.js",
      "import": "./src/control-plane/index.ts",
      "default": "./src/control-plane/index.ts"
    },
    "./control-plane/runtime": {
      "types": "./src/control-plane/runtime/index.ts",
      "node": "./dist/control-plane/runtime/index.js",
      "import": "./src/control-plane/runtime/index.ts",
      "default": "./src/control-plane/runtime/index.ts"
    },
    "./data-plane": {
      "types": "./src/data-plane/index.ts",
      "node": "./dist/data-plane/index.js",
      "import": "./src/data-plane/index.ts",
      "default": "./src/data-plane/index.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "node": "./dist/*.js",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run -c vitest.config.ts --passWithNoTests",
    "test:integration": "vitest run -c vitest.integration.config.ts --passWithNoTests",
    "test:property": "vitest run --passWithNoTests",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@mistle/automations": "workspace:*",
    "@mistle/db": "workspace:*",
    "@mistle/emails": "workspace:*",
    "@mistle/integrations-core": "workspace:*",
    "@mistle/sandbox": "workspace:*",
    "@mistle/time": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "openworkflow": "^0.8.1",
    "postgres": "^3.4.8",
    "typeid-js": "^1.2.0"
  },
  "devDependencies": {
    "@mistle/test-harness": "workspace:*",
    "zod": "^4.3.6"
  }
}
