{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "extends": ["../../.oxlintrc.jsonc"],
  "overrides": [
    {
      "files": ["src/**/*.ts", "src/**/*.tsx"],
      "rules": {
        "mistle/no-qualified-timer-globals": "off",
        "eslint/no-restricted-globals": "off",
      },
    },
  ],
}
