{
  "name": "@mistle/test-harness",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run -c vitest.config.ts --passWithNoTests",
    "test:integration": "vitest run -c vitest.integration.config.ts --passWithNoTests",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@mistle/time": "workspace:*",
    "@testcontainers/postgresql": "^11.12.0",
    "mailpit-api": "^1.7.2",
    "testcontainers": "^11.7.2",
    "zod": "^4.3.6"
  }
}
