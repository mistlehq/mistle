{
  "name": "@mistle/automations",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./webhook-filter": {
      "types": "./src/webhook-filter/index.ts",
      "node": "./dist/webhook-filter/index.js",
      "import": "./src/webhook-filter/index.ts",
      "default": "./src/webhook-filter/index.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "node": "./dist/*.js",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
