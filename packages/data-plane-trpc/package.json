{
  "name": "@mistle/data-plane-trpc",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "node": "./dist/client.js",
      "import": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./constants": {
      "types": "./src/constants.ts",
      "node": "./dist/constants.js",
      "import": "./src/constants.ts",
      "default": "./src/constants.ts"
    },
    "./contracts": {
      "types": "./src/contracts/index.ts",
      "node": "./dist/contracts/index.js",
      "import": "./src/contracts/index.ts",
      "default": "./src/contracts/index.ts"
    },
    "./contracts/*": {
      "types": "./src/contracts/*.ts",
      "node": "./dist/contracts/*.js",
      "import": "./src/contracts/*.ts",
      "default": "./src/contracts/*.ts"
    },
    "./router": {
      "types": "./src/router.ts",
      "node": "./dist/router.js",
      "import": "./src/router.ts",
      "default": "./src/router.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "node": "./dist/*.js",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings -c ./.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@mistle/db": "workspace:*",
    "@mistle/sandbox": "workspace:*",
    "@mistle/workflows": "workspace:*",
    "@trpc/client": "^11.11.0",
    "@trpc/server": "^11.12.0",
    "zod": "^4.3.6"
  }
}
