{
  "name": "@mistle/workflow-registry",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./control-plane": {
      "types": "./src/control-plane.ts",
      "node": "./dist/control-plane.js",
      "import": "./src/control-plane.ts",
      "default": "./src/control-plane.ts"
    },
    "./data-plane": {
      "types": "./src/data-plane.ts",
      "node": "./dist/data-plane.js",
      "import": "./src/data-plane.ts",
      "default": "./src/data-plane.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "node": "./dist/*.js",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "oxlint --type-aware --deny-warnings -c ../../.oxlintrc.jsonc .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@mistle/db": "workspace:*",
    "@mistle/integrations-core": "workspace:*",
    "@mistle/sandbox": "workspace:*",
    "openworkflow": "^0.8.1"
  }
}
