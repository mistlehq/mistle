# Copy this file to .env.test for local test secrets and opt-in test toggles.
# Do not commit .env.test.
# Generated integration/system test runtime context is written to .local/test-context/*.json.

# Real API key for Codex-backed integration/system tests.
MISTLE_TEST_OPENAI_API_KEY=

# GitHub token with access to the test repository and installation.
MISTLE_TEST_GITHUB_TOKEN=

# Repository used by GitHub-related system tests, in owner/repo format.
MISTLE_TEST_GITHUB_TEST_REPOSITORY=

# GitHub App installation id for the test repository.
MISTLE_TEST_GITHUB_INSTALLATION_ID=

# Optional: @mistle/sandbox integration tests.
# Set to 1 to enable sandbox package integration tests.
MISTLE_TEST_SANDBOX_INTEGRATION=

# Comma-separated providers to run (currently: docker).
MISTLE_TEST_SANDBOX_INTEGRATION_PROVIDERS=

# Optional: override the Docker socket path for docker provider integration tests.
# Defaults to /var/run/docker.sock when unset.
MISTLE_SANDBOX_DOCKER_SOCKET_PATH=
