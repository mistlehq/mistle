{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "builtin": true,
  },
  "jsPlugins": ["./tools/oxlint-plugins/no-qualified-timer-globals.js"],
  "plugins": ["eslint", "typescript", "node", "vitest"],
  "rules": {
    "mistle/no-qualified-timer-globals": "error",
    "typescript/no-deprecated": "error",
    "eslint/no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "node:timers/promises",
            "message": "Use @mistle/time abstractions instead of node:timers/promises in runtime code.",
          },
          {
            "name": "timers/promises",
            "message": "Use @mistle/time abstractions instead of timers/promises in runtime code.",
          },
          {
            "name": "node:timers",
            "message": "Use @mistle/time abstractions instead of node:timers in runtime code.",
          },
          {
            "name": "timers",
            "message": "Use @mistle/time abstractions instead of timers in runtime code.",
          },
          {
            "name": "vitest",
            "importNames": ["vi"],
            "message": "Do not use vi-based mocks/spies. Assert observable behavior instead.",
          },
          {
            "name": "jest",
            "message": "Do not use jest mocking APIs. Assert observable behavior instead.",
          },
          {
            "name": "@jest/globals",
            "message": "Do not use jest globals for mocking/spying.",
          },
          {
            "name": "sinon",
            "message": "Do not use sinon fakes/stubs/spies.",
          },
          {
            "name": "nock",
            "message": "Do not use nock-based request mocking.",
          },
          {
            "name": "msw",
            "message": "Do not use MSW-based request mocking.",
          },
          {
            "name": "testdouble",
            "message": "Do not use testdouble-based mocking.",
          },
          {
            "name": "ts-mockito",
            "message": "Do not use ts-mockito-based mocking.",
          },
          {
            "name": "typemoq",
            "message": "Do not use typemoq-based mocking.",
          },
          {
            "name": "fetch-mock",
            "message": "Do not use fetch-mock-based request mocking.",
          },
        ],
      },
    ],
    "eslint/no-restricted-globals": [
      "error",
      {
        "name": "setTimeout",
        "message": "Use @mistle/time abstractions instead of global setTimeout.",
      },
      {
        "name": "clearTimeout",
        "message": "Use @mistle/time abstractions instead of global clearTimeout.",
      },
      {
        "name": "setInterval",
        "message": "Use @mistle/time abstractions instead of global setInterval.",
      },
      {
        "name": "clearInterval",
        "message": "Use @mistle/time abstractions instead of global clearInterval.",
      },
      {
        "name": "vi",
        "message": "Do not use vi-based mocks/spies. Assert observable behavior instead.",
      },
      {
        "name": "jest",
        "message": "Do not use jest-based mocks/spies. Assert observable behavior instead.",
      },
    ],
    "eslint/no-restricted-properties": [
      "error",
      {
        "object": "vi",
        "property": "fn",
        "message": "Do not use vi.fn mocks/stubs. Assert observable behavior instead.",
      },
      {
        "object": "vi",
        "property": "spyOn",
        "message": "Do not use vi.spyOn. Assert observable behavior instead.",
      },
      {
        "object": "vi",
        "property": "mock",
        "message": "Do not use vi.mock. Assert observable behavior instead.",
      },
      {
        "object": "vi",
        "property": "mocked",
        "message": "Do not use vi.mocked. Assert observable behavior instead.",
      },
      {
        "object": "vi",
        "property": "stubGlobal",
        "message": "Do not stub globals in tests. Assert observable behavior instead.",
      },
      {
        "object": "jest",
        "property": "fn",
        "message": "Do not use jest.fn mocks/stubs. Assert observable behavior instead.",
      },
      {
        "object": "jest",
        "property": "spyOn",
        "message": "Do not use jest.spyOn. Assert observable behavior instead.",
      },
      {
        "object": "jest",
        "property": "mock",
        "message": "Do not use jest.mock. Assert observable behavior instead.",
      },
      {
        "object": "jest",
        "property": "mocked",
        "message": "Do not use jest.mocked. Assert observable behavior instead.",
      },
      {
        "object": "sinon",
        "property": "stub",
        "message": "Do not use sinon stubs. Assert observable behavior instead.",
      },
      {
        "object": "sinon",
        "property": "spy",
        "message": "Do not use sinon spies. Assert observable behavior instead.",
      },
      {
        "object": "sinon",
        "property": "mock",
        "message": "Do not use sinon mocks. Assert observable behavior instead.",
      },
    ],
  },
  "overrides": [
    {
      "files": [
        "apps/control-plane-api/**/*.ts",
        "apps/control-plane-api/**/*.tsx",
        "apps/control-plane-worker/**/*.ts",
        "apps/control-plane-worker/**/*.tsx",
        "apps/data-plane-api/**/*.ts",
        "apps/data-plane-api/**/*.tsx",
        "apps/data-plane-worker/**/*.ts",
        "apps/data-plane-worker/**/*.tsx",
        "apps/data-plane-gateway/**/*.ts",
        "apps/data-plane-gateway/**/*.tsx",
      ],
      "rules": {
        "eslint/no-restricted-syntax": [
          "error",
          {
            "selector": "ImportDeclaration[source.value=/^@mistle\\/test-environments(?:\\/.*)?$/]",
            "message": "Do not import @mistle/test-environments in backend app workspaces. Use app-local integration fixtures or @mistle/test-core. @mistle/test-environments is reserved for dashboard and tests/system/e2e.",
          },
          {
            "selector": "ExportNamedDeclaration[source.value=/^@mistle\\/test-environments(?:\\/.*)?$/]",
            "message": "Do not re-export @mistle/test-environments from backend app workspaces. @mistle/test-environments is reserved for dashboard and tests/system/e2e.",
          },
          {
            "selector": "ExportAllDeclaration[source.value=/^@mistle\\/test-environments(?:\\/.*)?$/]",
            "message": "Do not re-export @mistle/test-environments from backend app workspaces. @mistle/test-environments is reserved for dashboard and tests/system/e2e.",
          },
          {
            "selector": "ImportExpression[source.value=/^@mistle\\/test-environments(?:\\/.*)?$/]",
            "message": "Do not import @mistle/test-environments in backend app workspaces. Use app-local integration fixtures or @mistle/test-core. @mistle/test-environments is reserved for dashboard and tests/system/e2e.",
          },
        ],
      },
    },
    {
      "files": ["apps/dashboard/**/*.ts", "apps/dashboard/**/*.tsx"],
      "rules": {
        "eslint/no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "@mistle/integrations-definitions/openai/agent",
                "message": "Dashboard must not import the server-only OpenAI agent entrypoint. Use @mistle/integrations-definitions/openai/agent/browser.",
              },
            ],
            "patterns": [
              {
                "group": ["@mistle/codex-app-server-client", "@mistle/codex-app-server-client/*"],
                "message": "Dashboard Codex imports must come through @mistle/integrations-definitions/openai/agent/browser.",
              },
              {
                "group": ["../../../../../packages/codex-app-server-client/src/**"],
                "message": "Do not deep-import codex-app-server-client source files from dashboard code.",
              },
              {
                "group": ["../../../../../packages/integrations-definitions/src/**"],
                "message": "Do not deep-import integrations-definitions source files from dashboard code. Use the exported OpenAI browser entrypoint.",
              },
            ],
          },
        ],
      },
    },
    {
      "files": [
        "apps/control-plane-api/src/**/*.ts",
        "apps/control-plane-worker/src/**/*.ts",
        "apps/data-plane-api/src/**/*.ts",
        "apps/data-plane-worker/src/**/*.ts",
        "apps/data-plane-gateway/src/**/*.ts",
        "packages/logging/src/**/*.ts",
      ],
      "rules": {
        "eslint/no-console": "error",
      },
    },
  ],
  "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/coverage/**", "**/.turbo/**"],
}
