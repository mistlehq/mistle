{
  "name": "mistle",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx ./scripts/dev/start.ts",
    "dev:nix": "nix develop --command pnpm dev",
    "dev:workspace": "turbo watch dev --ui=tui --env-mode=loose --filter=!@mistle/docs --filter=!@mistle/sandbox-runtime",
    "storybook": "pnpm --filter @mistle/storybook storybook",
    "storybook:build": "pnpm --filter @mistle/storybook build-storybook",
    "dev:down": "tsx ./scripts/dev/down.ts",
    "dev:reset": "tsx ./scripts/dev/down.ts --volumes",
    "dev:reset:hard": "tsx ./scripts/dev/down.ts --volumes --rmi-local",
    "build": "turbo run build",
    "build:sandbox-runtime:sea:linux": "node ./scripts/build/build-sandbox-runtime-sea-linux.mjs",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "pnpm lint:oxlint && pnpm lint:extra",
    "lint:workspace": "pnpm lint:oxlint",
    "lint:oxlint": "oxlint --type-aware --deny-warnings apps packages tests",
    "lint:extra": "pnpm lint:openapi && pnpm lint:docs && pnpm lint:rust",
    "lint:openapi": "pnpm --filter @mistle/control-plane-api openapi:check && pnpm --filter @mistle/data-plane-api openapi:check && pnpm --filter @mistle/control-plane-internal-client openapi:check && pnpm --filter @mistle/data-plane-internal-client openapi:check",
    "lint:docs": "pnpm --filter @mistle/docs lint",
    "lint:rust": "pnpm --filter @mistle/sandbox-rs-napi lint",
    "lint:spelling": "codespell",
    "lint:knip": "knip --config knip.jsonc --no-progress --reporter compact",
    "lint:knip:report": "knip --config knip.jsonc --no-progress --reporter compact --no-exit-code",
    "lint:jscpd": "jscpd --config .jscpd.json",
    "lint:sql": "pnpm --filter @mistle/db lint:sql",
    "lint:repo-health": "pnpm lint:knip && pnpm lint:jscpd && pnpm lint:sql",
    "lint-staged": "lint-staged",
    "config:init:dev": "tsx ./scripts/config/init-development.ts",
    "config:init:ci": "tsx ./scripts/config/init-ci.ts",
    "config:convert:env-to-toml": "tsx ./scripts/config/convert.ts env-to-toml",
    "config:convert:toml-to-env": "tsx ./scripts/config/convert.ts toml-to-env",
    "typecheck": "turbo run typecheck --output-logs=errors-only && pnpm typecheck:scripts",
    "typecheck:scripts": "tsc --project ./scripts/tsconfig.json",
    "test": "turbo run test --output-logs=errors-only",
    "test:coverage": "turbo run test --filter=!@mistle/docs --filter=!@mistle/sandbox-rs-napi --force --output-logs=errors-only -- --coverage.enabled --coverage.reporter=lcov --coverage.reporter=json-summary --coverage.reporter=text-summary",
    "test:coverage:rust": "LLVM_COV=\"$(command -v llvm-cov)\" LLVM_PROFDATA=\"$(command -v llvm-profdata)\" cargo llvm-cov --manifest-path packages/sandbox-rs-napi/Cargo.toml --locked --lcov --output-path packages/sandbox-rs-napi/coverage/lcov.info",
    "test:property": "turbo run test:property",
    "test:integration": "tsx ./scripts/test/run-integration-vitest.ts",
    "test:integration:all": "pnpm test:integration",
    "test:sandbox-runtime:sea:linux": "node ./scripts/test/run-sandbox-runtime-sea-linux.mjs",
    "test:system": "pnpm --filter @mistle/tests test:system",
    "test:e2e": "pnpm --filter @mistle/tests test:e2e",
    "release:start": "tsx ./scripts/release/start.ts",
    "release:prepare": "tsx ./scripts/release/prepare.ts",
    "release:validate-tag": "tsx ./scripts/release/validate-tag.ts",
    "release:notes": "tsx ./scripts/release/notes.ts",
    "release:write-notes": "tsx ./scripts/release/write-notes.ts",
    "release:create-tag": "tsx ./scripts/release/create-tag.ts",
    "ci": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm storybook:build && pnpm test",
    "ci:nix": "nix develop --command pnpm run ci",
    "prepare": "node -e \"const cp = require('child_process'); if (!(process.env.CI || process.env.LEFTHOOK === '0')) { try { cp.execSync('git rev-parse --is-inside-work-tree', { stdio: 'ignore' }); cp.execSync('lefthook install', { stdio: 'inherit' }); } catch {} }\""
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.58.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript/native-preview": "latest",
    "@vitest/coverage-v8": "^4.1.1",
    "jscpd": "^4.0.8",
    "knip": "^5.88.0",
    "lefthook": "^2.1.4",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "smol-toml": "^1.6.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": "^25.0.0",
    "pnpm": "10.30.2"
  },
  "packageManager": "pnpm@10.30.2"
}
