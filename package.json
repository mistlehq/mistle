{
  "name": "mistle",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx ./scripts/dev/start.ts",
    "dev:nix": "nix develop --command pnpm dev",
    "dev:workspace": "turbo watch dev --ui=tui --env-mode=loose --filter=!@mistle/docs",
    "storybook": "pnpm --filter @mistle/storybook storybook",
    "storybook:build": "pnpm --filter @mistle/storybook build-storybook",
    "dev:down": "tsx ./scripts/dev/down.ts",
    "dev:reset": "tsx ./scripts/dev/down.ts --volumes",
    "dev:reset:hard": "tsx ./scripts/dev/down.ts --volumes --rmi-local",
    "build": "turbo run build",
    "build:sandbox-runtime:sea:linux": "node ./scripts/build/build-sandbox-runtime-sea-linux.mjs",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "pnpm lint:workspace",
    "lint:workspace": "turbo run lint --output-logs=errors-only",
    "lint:knip": "knip --config knip.jsonc --no-progress --reporter compact --no-exit-code",
    "lint:jscpd": "jscpd --config .jscpd.json",
    "lint:sql": "pnpm --filter @mistle/db lint:sql",
    "lint:repo-health": "pnpm lint:knip && pnpm lint:jscpd && pnpm lint:sql",
    "lint-staged": "lint-staged",
    "config:init:dev": "tsx ./scripts/config/init-development.ts",
    "config:init:ci": "tsx ./scripts/config/init-ci.ts",
    "config:convert:env-to-toml": "tsx ./scripts/config/convert.ts env-to-toml",
    "config:convert:toml-to-env": "tsx ./scripts/config/convert.ts toml-to-env",
    "typecheck": "turbo run typecheck --output-logs=errors-only && pnpm typecheck:scripts",
    "typecheck:scripts": "tsc --project ./scripts/tsconfig.json",
    "test": "turbo run test --output-logs=errors-only",
    "test:property": "turbo run test:property",
    "test:integration": "tsx ./scripts/test/run-integration-vitest.ts",
    "test:integration:all": "pnpm test:integration",
    "test:sandbox-runtime:sea:linux": "node ./scripts/test/run-sandbox-runtime-sea-linux.mjs",
    "test:system": "pnpm --filter @mistle/tests test:system",
    "test:e2e": "pnpm --filter @mistle/tests test:e2e",
    "ci": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm storybook:build && pnpm test",
    "ci:nix": "nix develop --command pnpm run ci",
    "prepare": "node -e \"const cp = require('child_process'); if (!(process.env.CI || process.env.LEFTHOOK === '0')) { try { cp.execSync('git rev-parse --is-inside-work-tree', { stdio: 'ignore' }); cp.execSync('lefthook install', { stdio: 'inherit' }); } catch {} }\""
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@fast-check/vitest": "^0.3.0",
    "@playwright/test": "^1.58.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript/native-preview": "latest",
    "@vitest/coverage-v8": "^4.1.0",
    "fast-check": "^4.5.3",
    "jscpd": "^4.0.8",
    "knip": "^5.87.0",
    "lefthook": "^2.1.4",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.16.0",
    "smol-toml": "^1.6.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": "^25.0.0",
    "pnpm": "10.30.2"
  },
  "packageManager": "pnpm@10.30.2"
}
