{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "MISTLE_CONFIG_PATH",
    "MISTLE_GLOBAL_TELEMETRY_ENABLED",
    "MISTLE_GLOBAL_TELEMETRY_DEBUG",
    "MISTLE_GLOBAL_TELEMETRY_TRACES_ENDPOINT",
    "MISTLE_GLOBAL_TELEMETRY_LOGS_ENDPOINT",
    "MISTLE_GLOBAL_TELEMETRY_METRICS_ENDPOINT",
    "MISTLE_GLOBAL_TELEMETRY_RESOURCE_ATTRIBUTES"
  ],
  "tasks": {
    "dev": {
      "dependsOn": ["^build"],
      "passThroughEnv": ["MISTLE_*"],
      "cache": false,
      "persistent": true,
      "interruptible": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "passThroughEnv": ["MISTLE_*"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "passThroughEnv": ["MISTLE_*"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build", "^typecheck"],
      "passThroughEnv": ["MISTLE_*"],
      "outputs": []
    },
    "test:property": {
      "dependsOn": ["^build"],
      "passThroughEnv": ["MISTLE_*"],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "passThroughEnv": ["MISTLE_*"],
      "outputs": []
    }
  }
}
